# Copy this file to .env and fill in your keys
# Never commit .env to GitHub — it contains secrets

# Get this from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get this from https://www.notion.so/my-integrations → New integration
NOTION_API_KEY=your_notion_integration_token_here

# The ID of the Notion page where daily digests will be created as sub-pages
# Find it in the page URL: notion.so/Your-Page-Title-[THIS_PART]
NOTION_PARENT_PAGE_ID=your_notion_page_id_here
